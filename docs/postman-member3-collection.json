  "item": [
    {
      "name": "01. List Preferences",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/preferences",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "preferences"
          ]
        }
      },
      "response": []
    },
    {
      "name": "02. Signup (with preferenceIds)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('signup success', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "const json = pm.response.json();",
              "if (json && json.accessToken) {",
              "  pm.collectionVariables.set('accessToken', json.accessToken);",
              "}",
              "if (json && json.user && json.user.id) {",
              "  pm.collectionVariables.set('userId', String(json.user.id));",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"loginId\": \"{{loginId}}\",\n  \"password\": \"{{password}}\",\n  \"name\": \"홍길동\",\n  \"phone\": \"01012345678\",\n  \"nickname\": \"길동이\",\n  \"age\": 24,\n  \"preferenceIds\": [1, 3, 5]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/signup",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "signup"
          ]
        }
      },
      "response": []
    },
    {
      "name": "03. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('login success', function () {",
              "  pm.expect(pm.response.code).to.eql(200);",
              "});",
              "const json = pm.response.json();",
              "if (json && json.accessToken) {",
              "  pm.collectionVariables.set('accessToken', json.accessToken);",
              "}",
              "if (json && json.user && json.user.id) {",
              "  pm.collectionVariables.set('userId', String(json.user.id));",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"loginId\": \"{{loginId}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
